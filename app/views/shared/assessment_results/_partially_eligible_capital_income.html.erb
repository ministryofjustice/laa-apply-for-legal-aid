<header>
  <h1 class="govuk-heading-l moj-interruption-card__heading">
    <%= t(".heading", name: @legal_aid_application.applicant_full_name) %>
  </h1>
</header>

<p class="govuk-body moj-interruption-card__body"><%= t(".line_1") %></p>
<%= govuk_list t(".details",
                 capital_contribution: gds_number_to_currency(@cfe_result.capital_contribution),
                 income_contribution: gds_number_to_currency(@cfe_result.income_contribution)),
               type: :bullet,
               classes: "moj-interruption-card__body" %>

<p class="govuk-body moj-interruption-card__body"><%= t(".line_2") %></p>
<p class="govuk-body moj-interruption-card__body"><%= t(".line_3") %></p>
