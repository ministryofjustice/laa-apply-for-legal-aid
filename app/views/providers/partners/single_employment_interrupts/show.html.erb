<%= page_template(page_title: t("shared.single_employment_interrupts.title", individual: t("generic.partner")), template: :basic, column_width: "full") do %>
  <%= moj_interruption_card(heading: t("shared.single_employment_interrupts.title", individual: t("generic.partner"))) do |card| %>
    <% card.with_body do %>
      <p><%= t("shared.single_employment_interrupts.paragraph", individual: t("generic.partner")) %></p>
    <% end %>
    <% card.with_actions do %>
      <%= govuk_button_link_to t("generic.continue"), providers_legal_aid_application_partners_employment_income_path, inverse: true, role: "button" %>
      <%= govuk_link_to t("generic.back_to_your_applications"), home_path, inverse: true %>
    <% end %>
  <% end %>
<% end %>
