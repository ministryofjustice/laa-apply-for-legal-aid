<%= page_template(page_title: t("shared.employed_but_no_hmrc_data_interrupts.client_title"), template: :basic, column_width: "full") do %>
  <%= moj_interruption_card(heading: t("shared.employed_but_no_hmrc_data_interrupts.client_title")) do |card| %>
    <% card.with_body do %>
      <p><%= t("shared.employed_but_no_hmrc_data_interrupts.client_paragraph") %></p>
    <% end %>
    <% card.with_actions do %>
      <%= govuk_button_link_to t("generic.continue"), providers_legal_aid_application_means_full_employment_details_path, inverse: true, role: "button" %>
      <%= govuk_link_to t("generic.back_to_your_applications"), home_path, inverse: true %>
    <% end %>
  <% end %>
<% end %>
