<% individual = @legal_aid_application.applicant.has_partner_with_no_contrary_interest? ? I18n.t("generic.client_and_partner") : I18n.t("generic.client") %>

<%= page_template page_title: t(".heading", individual: individual.capitalize), back_link: back_link_unless(providers_legal_aid_application_means_check_income_answers_path) do %>
  <p class="govuk-body"><%= t(".capital_text") %></p>

  <%= govuk_list t(".capital_items"), type: :bullet %>

  <%= next_action_buttons_with_form(
        url: providers_legal_aid_application_capital_introduction_path,
        method: :patch,
        continue_button_text: t("generic.continue"),
        show_draft: true,
      ) %>
<% end %>
