<%= page_template(
      page_title: t(".heading_1"),
      column_width: :full,
      back_link: :none,
    ) do %>
  <% if @applications.present? %>
    <%= render "submitted_applications", pagy: @pagy %>
  <% else %>
    <p class="govuk-body"><%= t(".no_applications") %></p>
  <% end %>
<% end %>
